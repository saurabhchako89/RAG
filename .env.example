# ── LLM provider (set exactly one) ───────────────────────────────────────────
# Priority order: Claude → Groq → DeepSeek → OpenAI → Gemini
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
# openai (default) or huggingface (fully local, no key needed)
EMBEDDING_PROVIDER=openai
# Only used when EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Only used when EMBEDDING_PROVIDER=openai
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── GitHub connector ──────────────────────────────────────────────────────────
GITHUB_TOKEN=
# Comma-separated list of repos to sync e.g. owner/repo1,owner/repo2
GITHUB_REPOS=

# ── Notion connector ──────────────────────────────────────────────────────────
NOTION_TOKEN=
# Comma-separated Notion database IDs to sync
NOTION_DATABASE_IDS=

# ── OCI Object Storage ────────────────────────────────────────────────────────
# Leave blank to use local disk instead
OCI_BUCKET_NAME=
OCI_NAMESPACE=
OCI_REGION=us-ashburn-1
# Set to true on OCI VM (uses instance principal auth, no key file needed)
OCI_USE_INSTANCE_PRINCIPAL=false
